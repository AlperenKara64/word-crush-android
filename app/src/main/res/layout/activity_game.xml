<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/game_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/field_bright"
    tools:context=".GameActivity">

    <!-- Üst Panel: Skor, Hamle, Kullanıcı -->
    <LinearLayout
        android:id="@+id/topBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp"
        android:background="#A0FFFFFF"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/tvCurrentScore"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Puan: 0"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvRemainingMoves"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Hamle: 20"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="@android:color/holo_red_dark" />

            <ImageButton
                android:id="@+id/btnCheatMenu"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_marginStart="8dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@android:drawable/ic_menu_info_details"
                android:contentDescription="Cheat"
                app:tint="@color/material_dynamic_primary40" />
        </LinearLayout>

        <TextView
            android:id="@+id/tvPossibleWordsCount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Gridde Oluşturulabilir Kelime Sayısı: 0"
            android:textSize="14sp"
            android:layout_marginTop="4dp"
            android:textColor="@android:color/black" />

    </LinearLayout>

    <!-- Seçilen Kelime Önizleme -->
    <TextView
        android:id="@+id/tvSelectedWord"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text=""
        android:textSize="24sp"
        android:textStyle="bold"
        android:textColor="@color/material_dynamic_primary40"
        android:layout_marginBottom="16dp"
        app:layout_constraintBottom_toTopOf="@id/gridContainer"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Oyun Alanı (Grid) -->
    <FrameLayout
        android:id="@+id/gridContainer"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_margin="8dp"
        android:background="@drawable/field_dark"
        app:layout_constraintDimensionRatio="1:1"
        app:layout_constraintTop_toBottomOf="@id/topBar"
        app:layout_constraintBottom_toTopOf="@id/bottomPanel"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <GridLayout
            android:id="@+id/letterGrid"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@android:color/transparent"
            android:padding="2dp" />

    </FrameLayout>

    <!-- Alt Panel: Jokerler -->
    <HorizontalScrollView
        android:id="@+id/bottomPanel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="12dp"
        android:background="#40000000"
        app:layout_constraintBottom_toBottomOf="parent">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center">

            <!-- Joker Item Template (Balık) -->
            <FrameLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_margin="6dp">
                <ImageButton
                    android:id="@+id/btnJokerFish"
                    android:layout_width="56dp"
                    android:layout_height="56dp"
                    android:background="@drawable/bg_joker_button"
                    android:padding="8dp"
                    android:scaleType="fitCenter"
                    android:src="@drawable/ic_joker_fish"
                    android:contentDescription="Balık" />
                <TextView
                    android:id="@+id/tvCountFish"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:layout_gravity="top|end"
                    android:background="@drawable/tile_selected"
                    android:gravity="center"
                    android:text="0"
                    android:textColor="#000000"
                    android:textSize="10sp"
                    android:textStyle="bold" />
            </FrameLayout>

            <!-- Tekerlek -->
            <FrameLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_margin="6dp">
                <ImageButton
                    android:id="@+id/btnJokerWheel"
                    android:layout_width="56dp"
                    android:layout_height="56dp"
                    android:background="@drawable/bg_joker_button"
                    android:padding="8dp"
                    android:scaleType="fitCenter"
                    android:src="@drawable/ic_joker_wheel"
                    android:contentDescription="Tekerlek" />
                <TextView
                    android:id="@+id/tvCountWheel"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:layout_gravity="top|end"
                    android:background="@drawable/tile_selected"
                    android:gravity="center"
                    android:text="0"
                    android:textColor="#000000"
                    android:textSize="10sp"
                    android:textStyle="bold" />
            </FrameLayout>

            <!-- Lolipop -->
            <FrameLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_margin="6dp">
                <ImageButton
                    android:id="@+id/btnJokerLollipop"
                    android:layout_width="56dp"
                    android:layout_height="56dp"
                    android:background="@drawable/bg_joker_button"
                    android:padding="8dp"
                    android:scaleType="fitCenter"
                    android:src="@drawable/ic_joker_lollipop"
                    android:contentDescription="Lolipop" />
                <TextView
                    android:id="@+id/tvCountLollipop"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:layout_gravity="top|end"
                    android:background="@drawable/tile_selected"
                    android:gravity="center"
                    android:text="0"
                    android:textColor="#000000"
                    android:textSize="10sp"
                    android:textStyle="bold" />
            </FrameLayout>

            <!-- Serbest Değiştirme -->
            <FrameLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_margin="6dp">
                <ImageButton
                    android:id="@+id/btnJokerSwapFree"
                    android:layout_width="56dp"
                    android:layout_height="56dp"
                    android:background="@drawable/bg_joker_button"
                    android:padding="8dp"
                    android:scaleType="fitCenter"
                    android:src="@drawable/ic_joker_swap"
                    android:contentDescription="Swap" />
                <TextView
                    android:id="@+id/tvCountSwap"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:layout_gravity="top|end"
                    android:background="@drawable/tile_selected"
                    android:gravity="center"
                    android:text="0"
                    android:textColor="#000000"
                    android:textSize="10sp"
                    android:textStyle="bold" />
            </FrameLayout>

            <!-- Harf Karıştırma -->
            <FrameLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_margin="6dp">
                <ImageButton
                    android:id="@+id/btnJokerShuffle"
                    android:layout_width="56dp"
                    android:layout_height="56dp"
                    android:background="@drawable/bg_joker_button"
                    android:padding="8dp"
                    android:scaleType="fitCenter"
                    android:src="@drawable/ic_joker_shuffle"
                    android:contentDescription="Shuffle" />
                <TextView
                    android:id="@+id/tvCountShuffle"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:layout_gravity="top|end"
                    android:background="@drawable/tile_selected"
                    android:gravity="center"
                    android:text="0"
                    android:textColor="#000000"
                    android:textSize="10sp"
                    android:textStyle="bold" />
            </FrameLayout>

            <!-- Parti -->
            <FrameLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_margin="6dp">
                <ImageButton
                    android:id="@+id/btnJokerParty"
                    android:layout_width="56dp"
                    android:layout_height="56dp"
                    android:background="@drawable/bg_joker_button"
                    android:padding="8dp"
                    android:scaleType="fitCenter"
                    android:src="@drawable/ic_joker_party"
                    android:contentDescription="Party" />
                <TextView
                    android:id="@+id/tvCountParty"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:layout_gravity="top|end"
                    android:background="@drawable/tile_selected"
                    android:gravity="center"
                    android:text="0"
                    android:textColor="#000000"
                    android:textSize="10sp"
                    android:textStyle="bold" />
            </FrameLayout>

        </LinearLayout>
    </HorizontalScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>