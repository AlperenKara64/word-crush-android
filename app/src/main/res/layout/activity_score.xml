<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp"
    android:background="@drawable/background"
    tools:context=".ScoreActivity">

    <TextView
        android:id="@+id/tvScoreboardTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/scoreboard_title"
        android:textSize="24sp"
        android:textStyle="bold"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <!-- Özet Alanı -->
    <androidx.cardview.widget.CardView
        android:id="@+id/summaryCard"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        app:cardCornerRadius="8dp"
        app:cardElevation="4dp"
        app:layout_constraintTop_toBottomOf="@id/tvScoreboardTitle">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:id="@+id/tvTotalGames"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Toplam Oyun: 0"
                android:textSize="16sp" />

            <TextView
                android:id="@+id/tvHighestScore"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="En Yüksek Puan: 0"
                android:textSize="16sp" />

            <TextView
                android:id="@+id/tvAverageScore"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Ortalama Puan: 0"
                android:textSize="16sp" />

            <TextView
                android:id="@+id/tvTotalWords"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Toplam Kelime: 0"
                android:textSize="16sp" />

            <TextView
                android:id="@+id/tvLongestWordSummary"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="En Uzun Kelime: -"
                android:textSize="16sp" />

            <TextView
                android:id="@+id/tvTotalDuration"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Toplam Süre: 0 dk"
                android:textSize="16sp" />

        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- Oyun Listesi -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvGameHistory"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="16dp"
        app:layout_constraintTop_toBottomOf="@id/summaryCard"
        app:layout_constraintBottom_toBottomOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>