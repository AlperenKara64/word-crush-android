<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp"
    android:background="@drawable/background"
    tools:context=".MainActivity">

    <!-- ÜST BAR: Kullanıcı Adı (Sadece Login değilse görünür) -->
    <TextView
        android:id="@+id/tvUsernameDisplayTop"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/username_placeholder"
        android:textSize="18sp"
        android:textStyle="bold"
        android:textColor="@android:color/black"
        android:padding="8dp"
        android:background="?attr/selectableItemBackground"
        android:clickable="true"
        android:focusable="true"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <!-- 1. GİRİŞ EKRANI -->
    <LinearLayout
        android:id="@+id/loginScreenLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        android:orientation="vertical"
        android:gravity="center"
        android:visibility="visible">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/welcome_message"
            android:textSize="24sp"
            android:layout_marginBottom="24dp" />

        <EditText
            android:id="@+id/etUsernameInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/username_hint"
            android:inputType="textPersonName"
            android:maxLength="20"
            android:autofillHints="name" />

        <Button
            android:id="@+id/btnSaveUsername"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/save_and_continue"
            android:layout_marginTop="16dp" />
    </LinearLayout>

    <!-- 2. ANA MENÜ EKRANI -->
    <LinearLayout
        android:id="@+id/mainMenuLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        android:orientation="vertical"
        android:gravity="center"
        android:visibility="gone">

        <Button
            android:id="@+id/btnNewGame"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/new_game"
            android:textSize="20sp"
            android:layout_marginBottom="12dp" />

        <Button
            android:id="@+id/btnHighScores"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/high_scores"
            android:textSize="20sp"
            android:layout_marginBottom="12dp" />

        <Button
            android:id="@+id/btnMarket"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/market"
            android:textSize="20sp" />
    </LinearLayout>

    <!-- 3. GRİD SEÇİM EKRANI -->
    <LinearLayout
        android:id="@+id/gridSelectionLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        android:orientation="vertical"
        android:gravity="center"
        android:visibility="gone">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/select_grid_size"
            android:textSize="22sp"
            android:layout_marginBottom="24dp" />

        <Button
            android:id="@+id/btnGrid6x6"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/grid_6x6"
            android:layout_marginBottom="8dp" />

        <Button
            android:id="@+id/btnGrid8x8"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/grid_8x8"
            android:layout_marginBottom="8dp" />

        <Button
            android:id="@+id/btnGrid10x10"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/grid_10x10" />
    </LinearLayout>

    <!-- 4. HAMLE SEÇİM EKRANI -->
    <LinearLayout
        android:id="@+id/moveSelectionLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        android:orientation="vertical"
        android:gravity="center"
        android:visibility="gone">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/select_move_count"
            android:textSize="22sp"
            android:layout_marginBottom="24dp" />

        <Button
            android:id="@+id/btnMovesEasy"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/moves_easy"
            android:layout_marginBottom="8dp" />

        <Button
            android:id="@+id/btnMovesMedium"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/moves_medium"
            android:layout_marginBottom="8dp" />

        <Button
            android:id="@+id/btnMovesHard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/moves_hard" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>